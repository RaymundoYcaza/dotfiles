# Ollama — Variables de entorno
# Copiar a .env y ajustar según sea necesario
# ================================================

# Host de escucha (0.0.0.0 para exponer en la red local)
OLLAMA_HOST=0.0.0.0

# Puerto (por defecto 11434)
# OLLAMA_PORT=11434

# Debug
# OLLAMA_DEBUG=1

# Tiempo que el modelo permanece en memoria después de la última request
# OLLAMA_KEEP_ALIVE=5m

# Límite de VRAM para modelos (opcional)
# OLLAMA_MAX_LOADED_MODELS=1

# Número de hilos para CPU (útil si no hay GPU)
# OLLAMA_NUM_THREAD=4
